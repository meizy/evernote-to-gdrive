        <note>
          <title>Encrypted Content</title>
          <created>20240101T000000Z</created>
          <updated>20240101T000000Z</updated>

          <content><![CDATA[<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE en-note SYSTEM "http://xml.evernote.com/pub/en-note.dtd">
<en-note><div>Visible text<en-crypt>secret stuff</en-crypt>Also visible</div></en-note>]]></content>


        </note>
        <note>
          <title>Checkbox Note</title>
          <created>20240101T000000Z</created>
          <updated>20240101T000000Z</updated>

          <content><![CDATA[<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE en-note SYSTEM "http://xml.evernote.com/pub/en-note.dtd">
<en-note><div><en-todo checked="true"/>Buy milk <en-todo/>Call dentist</div></en-note>]]></content>


        </note>
</en-export>